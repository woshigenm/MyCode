   1          #include <REGX51.H>
   2          #include "LCD1602.h"
   3          #include "timer0.h"
   4          
   5          #define TIMER_US 10000 // Timer0 interrupt every 10ms
   6          #define FIRST_ROW 1
   7          #define SECOND_ROW 2
   8          
   9          void delay_ms(unsigned int ms);
  10          
  11          unsigned char second = 0, minute = 0, hour = 0;
  12          int main()
  13          {
  14   1          LCD_Init();
  15   1          Timer0_Init(TIMER_US); // Initialize Timer0 for 1 US
  16   1          
  17   1          LCD_ShowString(FIRST_ROW, 1, "Timer0 Test");
  18   1          while(1)
  19   1          {
  20   2              if(second >= 60)

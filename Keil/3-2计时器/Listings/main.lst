  39   2              LCD_ShowNum(SECOND_ROW, 4, minute, 2);
  40   2              LCD_ShowChar(SECOND_ROW, 6, ':');
  41   2              LCD_ShowNum(SECOND_ROW, 7, second, 2);
  42   2      
  43   2              delay_ms(100); // Update display every 100ms
  44   2          }
  45   1      }
  46          

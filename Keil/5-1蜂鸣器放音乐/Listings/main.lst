 213   6                              TL0 = (unsigned char)(FreqTable[FreqSelect]);
 214   6                              TR0 = 1;
 215   6                          }
 216   5                      }
 217   4                      while(K1 == 0); // 等待按键松手
 218   4                  }
 219   3              }
 220   2      
 221   2              // ---------------------------------------------------
 222   2              // 2. 音乐播放逻辑
 223   2              // ---------------------------------------------------
 224   2              if(!is_paused) 
 225   2              {
 226   3                  if(currentNote->noteIndex != END_MARKER)
 227   3                  {
 228   4                      // 处理音符发声或休止
 229   4                      if(currentNote->noteIndex == SILENCE) 
 230   4                      {
 231   5                          TR0 = 0;    // 遇到休止符，关闭定时器
 232   5                          beep = 0;   // 确保蜂鸣器关闭
 233   5                      }
 234   4                      else 
 235   4                      {
 236   5                          FreqSelect = currentNote->noteIndex;
 237   5                          TH0 = (unsigned char)(FreqTable[FreqSelect] >> 8);
 238   5                          TL0 = (unsigned char)(FreqTable[FreqSelect]);

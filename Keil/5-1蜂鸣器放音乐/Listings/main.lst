 150          // 定时器0初始化 (适配11.0592MHz晶振，16位模式)
 151          void Timer0_Init()
 152          {
 153   1              TMOD &= 0xF0;           //设置定时器模式
 154   1              TMOD |= 0x01;           //设置定时器模式
 155   1              TL0 = 0x00;             //设置定时初值
 156   1              TH0 = 0x00;             //设置定时初值
 157   1              ET0 = 1;           //允许定时器0中断
 158   1              EA = 1;            //开启总中断
 159   1          TR0 = 0;           //初始化时先不启动
 160   1      }
 161          
 162          // 1毫秒延时函数 (专为11.0592MHz晶振校准)
 163          void Delay(unsigned int ms)
 164          {
 165   1              unsigned char i, j;
 166   1          while(ms--)
 167   1          {
 168   2              i = 2;
 169   2              j = 220; // 11.0592MHz下的1ms循环次数
 170   2              do
 171   2              {
 172   3                  while (--j);
 173   3              } while (--i);
 174   2          }
 175   1      }

 204   5                          TR0 = 0;   // 暂停时关闭定时器
 205   5                          beep = 0;  // 确保蜂鸣器静音
 206   5                      }
 207   4                      else 
 208   4                      {
 209   5                          // 恢复播放时，重新装载频率并开启定时器

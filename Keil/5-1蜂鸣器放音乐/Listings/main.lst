 189   1          
 190   1          while(1)
 191   1          {
 192   2              // ---------------------------------------------------
 193   2              // 1. 按键控制逻辑（播放/暂停）
 194   2              // ---------------------------------------------------
 195   2              if(K1 == 0)
 196   2              {
 197   3                  Delay(20); // 按键消抖
 198   3                  if(K1 == 0)
 199   3                  {
 200   4                      is_paused = !is_paused; // 切换状态
 201   4                      
 202   4                      if(is_paused) 

   1          #include <REGX52.H>
   2          #include "MatrixLed.h"
   3          #include "Delay.h"
   4          
   5          #define MATRIX_LED_PORT         P0
   6          
   7          sbit _74HC595_RCLK = P3^5;//存储寄存器时钟输入引脚
   8          sbit _74HC595_SER  = P3^4;//串行数据输入引脚
   9          sbit _74HC595_SRCLK = P3^6;//移位寄存器时钟引脚
  10          
  11          void _74HC595_WriteByte(unsigned char Byte)
  12          {
  13   1              unsigned char i;
  14   1              for(i = 0; i < 8; ++i)
  15   1              {
  16   2                      _74HC595_SER = Byte & (0x80 >> i);
  17   2                      _74HC595_SRCLK = 0;
  18   2                      _74HC595_SRCLK = 1;
  19   2              }
  20   1              
  21   1              _74HC595_RCLK = 0;
  22   1              _74HC595_RCLK = 1;
  23   1      }
  24          
  25          void MatrixLED(unsigned char Column, unsigned char Data)
  26          {
  27   1              _74HC595_WriteByte(Data);
  28   1              MATRIX_LED_PORT = ~(0x80>>Column); //共阳极
  29   1              Delay(1);
  30   1              MATRIX_LED_PORT = 0xFF;
  31   1      }



  30   1      }
  31          
  32          unsigned char DecToBcd(unsigned char Dec_Data)
  33          {
  34   1              return ((Dec_Data / 10) << 4) | (Dec_Data % 10);
  35   1      }
  36          
  37          unsigned char BcdToDec(unsigned char Bcd_Data)
  38          {
  39   1              return (Bcd_Data >> 4) * 10 + (Bcd_Data & 0x0F);
  40   1      }
  41          
  42          void DS1302_WriteByte(unsigned char Command, unsigned char Data)
  43          {
  44   1              unsigned char i;
  45   1              
  46   1              DS1302_CE = 0;

  97          void SetTime()
  98          {
  99   1              DS1302_WriteByte(0x8E, 0x00);
 100   1              
 101   1              DS1302_WriteByte(DS1302_SECONDS_WADDR, DecToBcd(Time[SECONDS])); // 秒 (清除CH位)

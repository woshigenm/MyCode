  18          void DS1302_Init()
  19          {
  20   1              unsigned char sec;
  21   1              
  22   1          DS1302_WriteByte(DS1302_WP_WADDR, 0x00);
  23   1              
  24   1              for(sec = 0; sec < sizeof(Command); ++sec)
  25   1              {
  26   2                      DS1302_WriteByte(Command[sec], DecToBcd(Time[sec]));
  27   2              }
  28   1              

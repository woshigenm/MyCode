 103   1          DS1302_WriteByte(DS1302_HOUR_WADDR, DecToBcd(Time[HOUR]));           // 时
 104   1          DS1302_WriteByte(DS1302_DATE_WADDR, DecToBcd(Time[DATE]));          // 日
 105   1          DS1302_WriteByte(DS1302_MONTH_WADDR , DecToBcd(Time[MONTH]));         // 月
 106   1          DS1302_WriteByte(DS1302_YEAR_WADDR, DecToBcd(Time[YEAR]));           // 年 
 107   1              
 108   1              DS1302_WriteByte(0x8E, 0x80);
 109   1      }

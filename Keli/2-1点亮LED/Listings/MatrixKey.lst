line level    source

   1          #include <REGX51.H>
   2          #include "Delay.h"
   3          #include "MatrixKey.h"
   4          
   5          #define ROW 4
   6          #define COL 4
   7          
   8          /**
   9           * @brief 矩阵键盘扫描函数
  10           * @return 按键值 (0表示无按键)
  11          */
  12          unsigned char MatrixKey() {
  13   1          static const unsigned char KeyMap[4][4] = {
  14   1              {KEY_1, KEY_4, KEY_7, KEY_16},   // 第0行
  15   1              {KEY_2, KEY_5, KEY_8, KEY_15},   // 第1行
  16   1              {KEY_3, KEY_6, KEY_9, KEY_14},   // 第2行
  17   1              {KEY_10, KEY_11, KEY_12, KEY_13} // 第3行
  18   1          };
  19   1          
  20   1          unsigned char i, j;
  21   1          for(i = 0; i < ROW; ++i) {
  22   2              P1 = 0xFF;
  23   2              P1 &= ~(1 << (3 - i));
  24   2              
  25   2              for(j = 0; j < COL; ++j) {
  26   3                  if(!(P1 & (1 << (j + 4)))) {
  27   4                      Delay(5);
  28   4                      while(!(P1 & (1 << (j + 4))));
  29   4                      return KeyMap[i][j];
  30   4                  }
  31   3              }
  32   2          }
  33   1          
  34   1          return 0;
  35   1      }
